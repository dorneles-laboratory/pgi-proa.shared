{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true, // Ativa verificações padrão
    "esModuleInterop": true, // Ajuda com libs CommonJS
    "forceConsistentCasingInFileNames": true, // Consistência em imports
    "verbatimModuleSyntax": true, // Mantém a sintaxe de módulos
    "isolatedModules": true, // Garante que cada arquivo seja seguro individualmente
    "skipLibCheck": true // Ignora erros em libs de terceiros (zod)
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
