{
  "name": "@lib/shared",
  "version": "1.0.0",
  "description": "Tipos e Schemas compartilhados",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "removeComments": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "watch": "tsc -w",
    "prepare": "npm run build && husky",
    "test": "vitest run",
    "dev": "tsc --watch",
    "test-watch": "vitest --watch",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "format": "prettier --write .",
    "format-check": "prettier --check ."
  },
  "keywords": [],
  "author": "Eng. Fernando Dorneles da Silva",
  "license": "ISC",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  }
}
